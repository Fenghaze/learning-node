<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel='stylesheet' href='/stylesheets/style.css'>
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body>
  <div class="container">
    <h1><%= title %></h1>

    <!-- 操作区 -->
    <div class="action-bar">
      <a href="/export" class="btn btn-primary">导出 Excel</a>
    </div>

    <!-- 消息提示 -->
    <% if (error) { %>
      <div class="message error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="message success"><%= success %></div>
    <% } %>

    <!-- 统计卡片 -->
    <div class="stats">
      <div class="stat-card income">
        <span class="stat-label">总收入</span>
        <span class="stat-value">¥<%= stats.totalIncome.toFixed(2) %></span>
      </div>
      <div class="stat-card expense">
        <span class="stat-label">总支出</span>
        <span class="stat-value">¥<%= stats.totalExpense.toFixed(2) %></span>
      </div>
      <div class="stat-card balance <%= stats.balance < 0 ? 'negative' : '' %>">
        <span class="stat-label">余额</span>
        <span class="stat-value">¥<%= stats.balance.toFixed(2) %></span>
      </div>
    </div>

    <!-- 图表区域 -->
    <div class="chart-container">
      <div class="chart-wrapper">
        <canvas id="trendChart"></canvas>
      </div>
      <div class="chart-wrapper">
        <canvas id="categoryChart"></canvas>
      </div>
    </div>

    <!-- 分类统计 -->
    <% if (Object.keys(categoryStats).length > 0) { %>
      <div class="category-stats">
        <h3>支出分类统计</h3>
        <div class="category-list">
          <% Object.entries(categoryStats).forEach(([cat, amount]) => { %>
            <div class="category-item">
              <span class="category-name"><%= cat %></span>
              <span class="category-amount">¥<%= amount.toFixed(2) %></span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <!-- 查询功能区域 -->
    <div class="form-section">
      <h2>查询账单</h2>
      <form action="/query" method="POST" class="query-form" id="queryForm">
        <input type="hidden" name="page" id="queryPage" value="1">
        <div class="form-row">
          <div class="form-group">
            <label>开始日期</label>
            <input type="date" name="startDate" value="<%= typeof query !== 'undefined' ? query.startDate || '' : '' %>">
          </div>
          <div class="form-group">
            <label>结束日期</label>
            <input type="date" name="endDate" value="<%= typeof query !== 'undefined' ? query.endDate || '' : '' %>">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>类型</label>
            <select name="type">
              <option value="all" <%= typeof query !== 'undefined' && query.type === 'all' ? 'selected' : '' %>>全部</option>
              <option value="income" <%= typeof query !== 'undefined' && query.type === 'income' ? 'selected' : '' %>>收入</option>
              <option value="expense" <%= typeof query !== 'undefined' && query.type === 'expense' ? 'selected' : '' %>>支出</option>
            </select>
          </div>
          <div class="form-group">
            <label>分类</label>
            <select name="category">
              <option value="all" <%= typeof query !== 'undefined' && query.category === 'all' ? 'selected' : '' %>>全部</option>
              <% expenseCategories.forEach(cat => { %>
                <option value="<%= cat %>" <%= typeof query !== 'undefined' && query.category === cat ? 'selected' : '' %>><%= cat %></option>
              <% }) %>
            </select>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>最小金额</label>
            <input type="number" name="minAmount" step="0.01" min="0" placeholder="0.00" value="<%= typeof query !== 'undefined' ? query.minAmount || '' : '' %>">
          </div>
          <div class="form-group">
            <label>最大金额</label>
            <input type="number" name="maxAmount" step="0.01" min="0" placeholder="999999.99" value="<%= typeof query !== 'undefined' ? query.maxAmount || '' : '' %>">
          </div>
          <div class="form-group">
            <label>每页条数</label>
            <select name="limit" id="limitSelect" onchange="document.getElementById('queryPage').value='1'; this.form.submit();">
              <option value="5" <%= typeof pageLimit !== 'undefined' && pageLimit == 5 ? 'selected' : '' %>>5</option>
              <option value="10" <%= typeof pageLimit !== 'undefined' && pageLimit == 10 ? 'selected' : '' %>>10</option>
              <option value="15" <%= typeof pageLimit !== 'undefined' && pageLimit == 15 ? 'selected' : (typeof pageLimit === 'undefined' ? 'selected' : '') %>>15</option>
              <option value="30" <%= typeof pageLimit !== 'undefined' && pageLimit == 30 ? 'selected' : '' %>>30</option>
              <option value="100" <%= typeof pageLimit !== 'undefined' && pageLimit == 100 ? 'selected' : '' %>>100</option>
            </select>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">查询</button>
      </form>
    </div>

    <!-- 账单列表 -->
    <div class="form-section">
      <div class="batch-header">
        <h2>账单列表 (<%= accounts.length %> 条)</h2>
        <% if (typeof total !== 'undefined' && total > 0) { %>
          <div class="pagination-info">
            <span>共 <%= total %> 条</span>
            <% if (typeof currentPage === 'undefined') { %>
              <% var currentPage = 1; %>
            <% } %>
            <% if (typeof pageLimit === 'undefined') { %>
              <% var pageLimit = 15; %>
            <% } %>
            <% var totalPages = Math.ceil(total / pageLimit); %>
            <% if (totalPages > 1) { %>
              <div class="pagination">
                <% if (currentPage > 1) { %>
                  <button type="button" class="btn btn-sm" onclick="goToPage(<%= currentPage - 1 %>)">上一页</button>
                <% } %>
                <% for (var i = 1; i <= totalPages; i++) { %>
                  <% if (i === currentPage) { %>
                    <span class="page-current"><%= i %></span>
                  <% } else if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                    <button type="button" class="btn btn-sm" onclick="goToPage(<%= i %>)"><%= i %></button>
                  <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                    <span class="page-ellipsis">...</span>
                  <% } %>
                <% } %>
                <% if (currentPage < totalPages) { %>
                  <button type="button" class="btn btn-sm" onclick="goToPage(<%= currentPage + 1 %>)">下一页</button>
                <% } %>
              </div>
            <% } %>
          </div>
        <% } %>
        <% if (accounts.length > 0) { %>
          <div class="batch-actions">
            <label class="checkbox-label">
              <input type="checkbox" id="selectAll" onclick="toggleSelectAll(this)">
              全选
            </label>
            <button type="submit" form="batchDeleteForm" class="btn btn-danger" onclick="return confirmBatchDelete()">删除选中</button>
          </div>
        <% } %>
      </div>
      <form action="/batch-delete" method="POST" id="batchDeleteForm"></form>
      <div class="account-list" style="max-height: 60vh; overflow-y: auto;">
        <% if (accounts.length === 0) { %>
          <div class="empty-state">暂无账单记录</div>
        <% } else { %>
          <% accounts.forEach(account => { %>
            <div class="account-item <%= account.type %>">
              <div class="account-checkbox">
                <input type="checkbox" name="ids" value="<%= account.id %>" form="batchDeleteForm">
              </div>
              <div class="account-left">
                <div class="account-date"><%= account.date %></div>
                <div class="account-category">
                  <%= account.type === 'income' ? '收入' : account.category %>
                  <% if (account.remark) { %>
                    <span class="account-remark">(<%= account.remark %>)</span>
                  <% } %>
                </div>
              </div>
              <div class="account-right">
                <span class="account-amount <%= account.type %>">
                  <%= account.type === 'income' ? '+' : '-' %>¥<%= account.amount.toFixed(2) %>
                </span>
                <div class="account-actions">
                  <a href="/edit/<%= account.id %>" class="btn btn-sm btn-edit">编辑</a>
                  <a href="/delete/<%= account.id %>" class="btn btn-sm btn-delete" onclick="return confirm('确定要删除这条账单吗？');">删除</a>
                </div>
              </div>
            </div>
          <% }) %>
        <% } %>
      </div>
    </div>

    <!-- 添加账单表单 -->
    <div class="form-section">
      <h2>添加账单</h2>
      <form action="/add" method="POST" id="addForm">
        <div class="form-row">
          <div class="form-group">
            <label>日期 *</label>
            <input type="date" name="date" required value="<%= new Date().toISOString().split('T')[0] %>">
          </div>
          <div class="form-group">
            <label>类型 *</label>
            <select name="type" id="typeSelect" required>
              <option value="income">收入</option>
              <option value="expense" selected>支出</option>
            </select>
          </div>
        </div>
        <div class="form-row" id="categoryRow">
          <div class="form-group">
            <label>分类</label>
            <select name="category" id="categorySelect">
              <% expenseCategories.forEach(cat => { %>
                <option value="<%= cat %>"><%= cat %></option>
              <% }) %>
              <option value="custom">自定义...</option>
            </select>
          </div>
          <div class="form-group custom-category-group" style="display: none;">
            <label>自定义分类</label>
            <input type="text" name="customCategory" id="customCategory" placeholder="输入分类名称">
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>金额 *</label>
            <input type="number" name="amount" step="0.01" min="0.01" required placeholder="0.00">
          </div>
          <div class="form-group">
            <label>备注</label>
            <input type="text" name="remark" placeholder="选填" maxlength="200">
          </div>
        </div>
        <button type="submit" class="btn btn-primary">添加</button>
      </form>
    </div>

  </div>

  <script>
    // 类型切换
    document.getElementById('typeSelect').addEventListener('change', function() {
      const categoryRow = document.getElementById('categoryRow');
      if (this.value === 'expense') {
        categoryRow.style.display = 'block';
      } else {
        categoryRow.style.display = 'none';
      }
    });

    // 自定义分类
    document.getElementById('categorySelect').addEventListener('change', function() {
      const customGroup = document.querySelector('.custom-category-group');
      if (this.value === 'custom') {
        customGroup.style.display = 'block';
        document.getElementById('customCategory').required = true;
        document.getElementById('customCategory').name = 'category';
        document.getElementById('categorySelect').name = '';  // 避免两个字段同时提交 category
      } else {
        customGroup.style.display = 'none';
        document.getElementById('customCategory').required = false;
        document.getElementById('customCategory').name = 'customCategory';
        document.getElementById('categorySelect').name = 'category';
      }
    });

    // 清空所有确认
    function confirmClearAll() {
      if (confirm('确定要清空所有账单吗？此操作不可恢复！')) {
        document.getElementById('clearAllForm').submit();
      }
    }

    // 批量删除确认
    function confirmBatchDelete() {
      const checked = document.querySelectorAll('input[name="ids"]:checked');
      if (checked.length === 0) {
        alert('请选择要删除的账单');
        return false;
      }
      return confirm('确定要删除选中的 ' + checked.length + ' 条账单吗？此操作不可恢复！');
    }

    // 全选/取消全选
    function toggleSelectAll(source) {
      const checkboxes = document.querySelectorAll('input[name="ids"]');
      checkboxes.forEach(cb => cb.checked = source.checked);
    }

    // 分页导航
    function goToPage(pageNum) {
      document.getElementById('queryPage').value = pageNum;
      document.getElementById('queryForm').submit();
    }
  </script>
  <script src="/javascripts/charts.js"></script>
</body>
</html>
